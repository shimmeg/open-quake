{
  "name": "open-quake",
  "version": "0.2.2",
  "private": true,
  "description": "Open driver + multi-grid touchscreen launcher for the DK-QUAKE / ARIS-68 touchscreen-and-knob macro device.",
  "main": "app/main.js",
  "author": "TeeJS",
  "engines": {
    "node": ">=22.12 <27"
  },
  "scripts": {
    "start": "electron .",
    "start:win": "node build-smtc.js && electron .",
    "security:baseline": "node scripts/security/check-open-quake-security.mjs",
    "security:actions": "npm test",
    "security:macos": "node scripts/security/check-macos-build-config.mjs",
    "security:docs": "node scripts/security/check-macos-docs.mjs",
    "security:all": "npm run security:baseline && npm run security:actions && npm run security:macos && npm run security:docs",
    "test": "node --test \"scripts/security/test-*.mjs\"",
    "test:clock-layout": "node scripts/test-clock-layout.mjs",
    "rebuild": "electron-rebuild -f && npm run build:macos-media-helper",
    "build:smtc": "node build-smtc.js",
    "build:macos-media-helper": "node scripts/build-macos-media-key-helper.mjs",
    "predist": "npm run build:macos-media-helper",
    "dist": "electron-builder --mac",
    "predist:mac": "npm run build:macos-media-helper",
    "dist:mac": "electron-builder --mac",
    "predist:mac:dir": "npm run build:macos-media-helper",
    "dist:mac:dir": "electron-builder --mac dir",
    "dist:win": "node build-smtc.js && electron-builder --win"
  },
  "license": "SEE LICENSE IN LICENSE",
  "keywords": [
    "dk-quake",
    "aris-68",
    "decokee",
    "stream-deck",
    "macropad",
    "node-hid",
    "electron"
  ],
  "dependencies": {
    "node-hid": "^3.3.0",
    "systeminformation": "^5.31.7"
  },
  "optionalDependencies": {
    "robotjs": "^0.7.1"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "build": {
    "appId": "com.teejs.openquake",
    "productName": "open-quake",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "!app/config.json",
      "!docs/**",
      "!tools/**",
      "!native/**",
      "!build-smtc.js",
      "!sign.js",
      "!afterpack.js",
      "!.signing/**"
    ],
    "npmRebuild": false,
    "afterPack": "./afterpack.js",
    "asarUnpack": [
      "apps/**/*",
      "app/native/**",
      "**/*.node"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity",
      "icon": "packaging/macos/icon.png",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "packaging/macos/entitlements.mac.plist",
      "entitlementsInherit": "packaging/macos/entitlements.mac.plist",
      "artifactName": "open-quake-${version}-${arch}.${ext}",
      "extendInfo": {
        "NSMicrophoneUsageDescription": "open-quake records audio only while push-to-talk is held, then sends that clip to your configured Open WebUI transcription endpoint.",
        "NSHumanReadableCopyright": "Copyright TeeJS and contributors"
      }
    },
    "dmg": {
      "artifactName": "open-quake-${version}-${arch}.${ext}"
    },
    "win": {
      "target": [
        "portable",
        "nsis"
      ],
      "icon": "app/icon.png"
    },
    "portable": {
      "artifactName": "open-quake-${version}-portable.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "artifactName": "open-quake-${version}-setup.${ext}"
    }
  }
}
