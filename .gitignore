# dependencies
node_modules/

# build output
dist/
out/
build/

# user runtime config (seeded from app/config.default.json on first run — keeps personal setups out of git)
app/config.json

# local Azure Trusted Signing assets (3rd-party dlib + machine-specific metadata; re-fetched per machine)
.signing/

# logs
*.log
npm-debug.log*

# OS / editor cruft
.DS_Store
Thumbs.db
.vscode/
.idea/

# timestamped/.old backups of files (never committed)
*.old

# scratch handoff / homework notes (kept local, not part of the repo)
*-HANDOFF.md

# compiled SMTC album-art helper (built from native/smtc-art.cs by build-smtc.js; not a source artifact)
app/native/*.exe
