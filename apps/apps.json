[
  {
    "id": "clock",
    "name": "Flip Clock",
    "file": "clock.html",
    "options": [
      { "key": "mode",    "label": "Mode",          "type": "select", "default": "24",   "choices": [["24", "24-hour"], ["12", "12-hour"]] },
      { "key": "theme",   "label": "Theme",         "type": "select", "default": "dark", "choices": [["dark", "Dark"], ["classic", "Classic"]] },
      { "key": "seconds", "label": "Show seconds",  "type": "bool",   "default": false },
      { "key": "date",    "label": "Show date & day", "type": "bool", "default": true }
    ]
  },
  {
    "id": "music",
    "name": "Music",
    "file": "musicview.html",
    "served": true,
    "options": [],
    "grid": {
      "cols": 2,
      "rows": 2,
      "defaults": [
        { "label": "Spotify",     "icon": "🎵", "type": "url", "value": "https://open.spotify.com" },
        { "label": "YT Music",    "icon": "📺", "type": "url", "value": "https://music.youtube.com" },
        { "label": "Apple Music", "icon": "🍎", "type": "url", "value": "https://music.apple.com" },
        { "label": "Tidal",       "icon": "🌊", "type": "url", "value": "https://listen.tidal.com" }
      ]
    }
  },
  {
    "id": "chat",
    "name": "Open WebUI",
    "file": "chatview.html",
    "served": true,
    "options": [
      { "key": "endpoint", "label": "Open WebUI chat URL (…/api/chat/completions)", "type": "text", "default": "" },
      { "key": "api_key",  "label": "API key",                                       "type": "secret", "default": "", "help": "In Open WebUI: avatar (bottom-left) → Settings → Account → API Keys → Create new secret key (an admin may need to enable API keys first in Admin Panel → Settings → General → turn Enable API Keys on)." },
      { "key": "model",    "label": "Model (required, e.g. llama3.2)",               "type": "text", "default": "" }
    ]
  }
]
